# CinemaClip AI env template
# Скопируй в .env: cp .env.example .env
# Не коммить .env в git.

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Где взять: @BotFather -> /newbot (или существующий бот -> API Token)
BOT_TOKEN=your_telegram_bot_token

# URL Mini App (куда открывается WebApp в Telegram)
# Где взять: домен деплоя backend/frontend (Koyeb/Render/VPS), пример:
MINI_APP_URL=https://your-app.koyeb.app

# Опционально. Для webhook-режима бота:
# Где взять: публичный HTTPS URL backend, например https://your-app.koyeb.app
# Оставь пустым для polling-режима.
WEBHOOK_BASE_URL=

# ─── Groq ─────────────────────────────────────────────────────────────────────
# Где взять: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# Обычно оставляем дефолт
GROQ_LLAMA_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Где взять:
# Project Settings -> API -> Project URL
SUPABASE_URL=https://your-project.supabase.co

# Где взять:
# Project Settings -> API -> Project API Keys -> anon public
SUPABASE_KEY=your_supabase_anon_key

# ─── App ──────────────────────────────────────────────────────────────────────
# DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO

# Временная директория для ffmpeg и промежуточных файлов
TEMP_DIR=/tmp/cinemaclip

# true/false — включать водяной знак на видео
WATERMARK_ENABLED=true
WATERMARK_TEXT=@subtxtlab

# Порты приложения
HEALTH_PORT=8080
BACKEND_PORT=8000

# Лимит входного видео (МБ)
MAX_VIDEO_SIZE_MB=200
